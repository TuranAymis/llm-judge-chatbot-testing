# Copy to .env and fill in your keys (never commit .env).
# LLM_TYPE: openai (default, Gemini fallback if OpenAI fails) | gemini

OPENAI_API_KEY=
GEMINI_API_KEY=
LLM_TYPE=openai

# Chatbot E2E (Playwright): varsayılan https://monster.widget.aistudio.com.tr/
# CHATBOT_BASE_URL=https://monster.widget.aistudio.com.tr/
# CHATBOT_WIDGET_TIMEOUT_MS=60000
# Ön-kayıt (ad-soyad / e-posta) test verileri
# CHATBOT_TEST_NAME=Test Otomasyon
# CHATBOT_TEST_EMAIL=test@otomasyon.com
# Ön-kayıt adımlarında her bot cevabı için üst süre (ms), varsayılan 60000
# CHATBOT_PRE_CHAT_STEP_TIMEOUT_MS=60000
# Karşılama tespiti (virgülle ayrılmış alt dizgeler, küçük harfe çevrilir)
# CHATBOT_GREETING_MARKERS=merhaba,canavar destek,teknik destek
# Canlı duman testi: RUN_LIVE_WIDGET_SMOKE=1
